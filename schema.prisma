  /// Prevents duplicate keyword assignment on the same classification.
  @@unique([fileClassificationId, keywordId], map: "uq_file_classification_keywords_classification_keyword")
  /// Supports reverse lookups by keyword.
  @@index([keywordId], map: "idx_file_classification_keywords_keyword")
  /// Map this model to the existing file_classification_keywords table.
  @@map("file_classification_keywords")
}

/// Join table attaching grades to a file classification.
model FileClassificationGrade {
