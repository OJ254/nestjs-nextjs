// @/prisma/schema.prisma

/// Prisma Client generator used by the backend application and scripts.
generator client {
  /// Generate the JavaScript/TypeScript Prisma client.
  provider = "prisma-client"
  /// Keep generated artifacts outside the Prisma folder so application imports stay stable.
  output   = "../generated/prisma"
}

/// Primary PostgreSQL datasource for Ticet EDU application data.
datasource db {
  /// Prisma uses the PostgreSQL connector because Neon is Postgres-compatible.
  provider = "postgresql"
}

/// Business classification for a human user's primary product identity.
enum UserAccountType {
  /// Default human account type for general-purpose platform users.
  TICET_USER
  /// Learner account type with stricter elevation rules.
  STUDENT
  /// Educator/content-oriented account type without automatic admin power.
  INSTRUCTOR
}

/// Platform-wide administrative classification only.
enum UserAdministrativeRole {
  /// Standard user with no platform override privileges.
  NONE
  /// Highest platform administration role used only by Ticet staff.
  TICET_SUPER_ADMIN
}

/// Lifecycle state for a user account inside the application.
enum UserStatus {
  /// Account is active and allowed to operate normally.
  ACTIVE
  /// Account is temporarily inactive without being deleted.
  INACTIVE
  /// Account is suspended due to policy or moderation action.
  SUSPENDED
  /// Account is logically deleted for product-facing behavior.
  DELETED
}

/// Review and lifecycle state for creator privileges.
enum CreatorStatus {
  /// User has not applied for creator privileges.
  NOT_APPLIED
  /// Application or review is currently pending.
  PENDING
  /// Creator privileges are currently approved.
  APPROVED
  /// Application was rejected.
  REJECTED
  /// Creator privileges are suspended temporarily.
  SUSPENDED
  /// Creator privileges were revoked permanently or administratively.
  REVOKED
}

/// Coarse onboarding progress state for product setup flows.
enum OnboardingStatus {
  /// Onboarding has not yet started.
  NOT_STARTED
  /// Onboarding is in progress.
  IN_PROGRESS
  /// Onboarding was completed.
  COMPLETED
}

/// Supported gender options currently captured by the profile model.
enum Gender {
  /// Male selection.
  MALE
  /// Female selection.
  FEMALE
}

/// Supported curricula offered by the product.
enum CurriculumCode {
  /// Competency-Based Education curriculum.
  CBE
  /// Cambridge curriculum.
  CAM
  /// Internal/extended curriculum code already present in the product.
  EDX
  /// International Baccalaureate curriculum.
  IB
}

/// High-level exam systems associated with curricula.
enum ExamSystems {
  /// International General Certificate of Secondary Education.
  IGCSE
  /// Competency-Based Education exam system.
  CBE
  /// International Baccalaureate exam system.
  IB
}

/// Institution category used for business segmentation.
enum InstitutionCategory {
  /// College or higher-education style institution bucket.
  COLLEGE
  /// Kindergarten-to-secondary institution bucket.
  K12
}

/// Institution education level taxonomy.
enum InstitutionLevel {
  /// Pre-primary education level.
  PRE_PRIMARY
  /// Primary education level.
  PRIMARY
  /// Secondary education level.
  SECONDARY
  /// Advanced-level institution bucket.
  ADVANCED
  /// Informal education provider bucket.
  INFORMAL
  /// Technical and vocational education bucket.
  TIVET
  /// University education level.
  UNIVERSITY
}

/// Top-level curriculum level grouping used by libraries and taxonomy.
enum CurriculumLevelType {
  /// K-12 taxonomy where subject/chapter/topic classification matters.
  K12
  /// Higher-education taxonomy where K-12 classification is optional.
  HE
}

/// Review workflow state for a creator application row.
enum CreatorApplicationStatus {
  /// Application is awaiting review.
  PENDING
  /// Application was approved.
  APPROVED
  /// Application was rejected.
  REJECTED
  /// Application needs manual escalation or more review.
  REVIEW_REQUIRED
}

/// Verification workflow state for institutions.
enum InstitutionVerificationStatus {
  /// Institution is awaiting review.
  PENDING
  /// Institution has passed verification.
  VERIFIED
  /// Institution failed verification.
  REJECTED
  /// Institution is suspended even if previously verified.
  SUSPENDED
}

/// Visibility setting for a library; visibility is separate from access grants.
enum LibraryVisibility {
  /// Only the owner and explicit grantees should access the library.
  PRIVATE
  /// Broadly discoverable library that still depends on platform entitlements.
  PUBLIC
  /// Library requires explicit access even when visible to eligible users.
  PROTECTED
  /// Library requires a paid library subscription.
  PREMIUM
}

/// Permission shape granted through library access rows.
enum LibraryAccessType {
  /// User can modify library content.
  EDITOR
  /// User can only consume/view the library.
  VIEWER
}

/// Lifecycle state for a library access row.
enum LibraryAccessStatus {
  /// Grant exists but is not yet active.
  PENDING
  /// Grant is currently active.
  ACTIVE
  /// Grant was revoked.
  REVOKED
}

/// External billing providers supported by the product.
enum BillingProvider {
  /// Stripe is the current provider integration.
  STRIPE
}

/// Provider-backed platform subscription state.
enum SubscriptionStatus {
  /// Subscription is in trial.
  TRIALING
  /// Subscription is active.
  ACTIVE
  /// Payment is overdue.
  PAST_DUE
  /// Subscription was canceled.
  CANCELED
  /// Subscription creation has not completed.
  INCOMPLETE
  /// Subscription period ended without renewal.
  EXPIRED
}

/// Product-level platform plans.
enum PlatformPlan {
  /// Free plan with strictly limited access.
  FREE
  /// Entry paid platform plan.
  BRONZE
  /// Deferred future platform plan.
  SILVER
  /// Deferred future platform plan.
  GOLD
  /// Deferred future platform plan.
  PLATINUM
}

/// Billing cadence options retained for platform pricing and subscriptions.
enum BillingCycle {
  /// Seven-day billing cycle.
  WEEK_7_DAYS
  /// Thirty-day billing cycle.
  MONTH_30_DAYS
  /// One-hundred-twenty-day billing cycle.
  FOUR_MONTHS_120_DAYS
  /// Three-hundred-sixty-five-day billing cycle.
  YEAR_365_DAYS
}

/// Library-specific paid subscription state.
enum PaidLibrarySubscriptionStatus {
  /// Subscription is active.
  ACTIVE
  /// Payment is overdue.
  PAST_DUE
  /// Subscription was canceled.
  CANCELED
  /// Subscription term ended.
  EXPIRED
}

/// Dependency lifecycle for minor/custodian policy.
enum DependencyStatus {
  /// User currently requires at least one active custodian.
  DEPENDENT
  /// User can transition to independence through an audited workflow.
  ELIGIBLE_FOR_INDEPENDENCE
  /// User no longer requires a custodian.
  INDEPENDENT
}

/// Relationship lifecycle between a dependent and a custodian.
enum CustodianRelationshipStatus {
  /// Link exists but has not been activated.
  PENDING
  /// Link is active.
  ACTIVE
  /// Link was revoked.
  REVOKED
  /// Invitation or request was declined.
  DECLINED
  /// Link or request expired.
  EXPIRED
}

/// Invitation lifecycle for custodian-linking workflows.
enum CustodianInvitationStatus {
  /// Invitation is awaiting action.
  PENDING
  /// Invitation was accepted.
  ACCEPTED
  /// Invitation was declined.
  DECLINED
  /// Invitation was revoked.
  REVOKED
  /// Invitation expired before use.
  EXPIRED
}

/// Direction and business meaning of a custodian invitation.
enum CustodianInvitationType {
  /// Custodian initiated the invite to a dependent.
  CUSTODIAN_INVITES_DEPENDENT
  /// Dependent initiated the invite to a custodian.
  DEPENDENT_INVITES_CUSTODIAN
  /// Existing custodian invited another custodian.
  CUSTODIAN_ADDS_CUSTODIAN
}

/// Durable audit event type for delegated-account activity.
enum DelegatedAccessEventType {
  /// Custodian or delegate started an acting session.
  SESSION_STARTED
  /// Custodian or delegate ended an acting session.
  SESSION_ENDED
  /// Account view occurred under delegated access.
  ACCOUNT_VIEWED
  /// Settings changed under delegated access.
  SETTINGS_UPDATED
  /// Billing changed under delegated access.
  BILLING_UPDATED
  /// Custodian relationship changed under delegated access.
  CUSTODIAN_RELATIONSHIP_UPDATED
  /// Generic fallback for additional audited user actions.
  USER_ACTION_EXECUTED
}

/// Membership row lifecycle shared by institutions and companies.
enum OrganizationMembershipStatus {
  /// Membership is pending acceptance or approval.
  PENDING
  /// Membership is active.
  ACTIVE
  /// Membership is suspended.
  SUSPENDED
  /// Membership is revoked.
  REVOKED
}

/// Institution-scoped role labels.
enum InstitutionMembershipRole {
  /// Institution administrator.
  ADMIN
  /// Institution librarian.
  LIBRARIAN
  /// General staff operator.
  STAFF
  /// Instructor attached to the institution.
  INSTRUCTOR
  /// Billing administrator for the institution.
  BILLING_ADMIN
}

/// Company-scoped role labels.
enum CompanyMembershipRole {
  /// Company administrator.
  ADMIN
  /// C-suite or executive operator.
  C_SUITE
  /// General company staff.
  STAFF
  /// Billing administrator for the company.
  BILLING_ADMIN
}

/// Malware or trust scan state for file assets.
enum FileScanStatus {
  /// Scan has not completed.
  PENDING
  /// Asset was scanned and deemed clean.
  CLEAN
  /// Asset is blocked after scanning.
  BLOCKED
}

/// Asset processing state for file assets.
enum FileProcessingStatus {
  /// Asset upload finished but processing has not started.
  UPLOADED
  /// Asset is currently processing.
  PROCESSING
  /// Asset is ready for use.
  READY
  /// Asset processing failed.
  FAILED
}

/// Lifecycle state for a logical file record, separate from per-asset processing.
enum FileLifecycleStatus {
  /// File record exists but is still a draft/incomplete upload.
  DRAFT
  /// File is published and intended for user consumption.
  PUBLISHED
  /// File was retired from active circulation without deleting history.
  ARCHIVED
}

/// Analytics event types retained as immutable history.
enum EngagementEventType {
  /// A view impression was recorded.
  VIEW
  /// A like action was recorded.
  LIKE
  /// A save/bookmark action was recorded.
  SAVE
  /// A rating event was recorded.
  RATE
  /// A completion event was recorded.
  COMPLETE
  /// A share intent or click was recorded.
  SHARE_CLICK
}

/// Notification row lifecycle.
enum NotificationStatus {
  /// Notification has not been read.
  UNREAD
  /// Notification has been read.
  READ
  /// Notification was soft-deleted from the user experience.
  DELETED
}

/// Supported material types for uploaded files.
enum CourseMaterial {
  /// Lecture notes or reference notes.
  LECTURE_NOTES
  /// Questions or exam-style paper.
  QUESTIONS
  /// Quiz material.
  QUIZ
  /// Lesson plan material.
  LESSON_PLAN
  /// Exercise material.
  EXERCISE
  /// Flashcard material.
  FLASHCARD
}

/// Logical role of a binary asset attached to a file.
enum FileAssetRole {
  /// Main downloadable/viewable content asset.
  PRIMARY_CONTENT
  /// Visual thumbnail asset.
  THUMBNAIL
  /// Answer sheet asset, valid only for question material.
  ANSWER_SHEET
}

/// Provenance of a file asset.
enum FileAssetSource {
  /// Uploaded by a user or operator.
  UPLOADED
  /// Generated by product-side processing.
  GENERATED
  /// Default/fallback asset supplied by the platform.
  FALLBACK
  /// Generated by an AI workflow.
  AI_GENERATED
}

/// Provenance and usage kind for image assets.
enum ImageAssetKind {
  /// User-uploaded profile image.
  USER_PROFILE_UPLOAD
  /// Platform-provided avatar option.
  PLATFORM_AVATAR
  /// Platform-provided timeline cover image.
  PLATFORM_TIMELINE_COVER
  /// Platform-provided library cover image.
  PLATFORM_LIBRARY_COVER
}

/// Core human account model anchored to Clerk but enriched with product-facing identity fields.
model User {
  /// Internal UUID primary key used across all relations.
  id                         String                 @id @default(uuid()) @db.Uuid
  /// Durable pointer to the canonical Clerk user identity.
  clerkUserId                String                 @unique @map("clerk_user_id")
  /// Optional product username for public identity, routing, and mention-style lookups.
  username                   String?                @unique
  /// Optional primary first/given name snapshot used by product UX.
  firstName                  String?                @map("first_name")
  /// Optional middle/additional name snapshot used by product UX.
  otherName                  String?                @map("other_name")
  /// Optional primary email snapshot for product querying and communication fallbacks.
  primaryEmail               String?                @unique @map("primary_email")
  /// High-level business classification for the user (mandatory and selected by user during onboarding).
  accountType                UserAccountType        @map("account_type")
  /// Platform-only administration scope.
  administrativeRole         UserAdministrativeRole @default(NONE) @map("administrative_role")
  /// Lifecycle state for the account.
  status                     UserStatus             @default(ACTIVE)
  /// Suspension timestamp when the account is blocked.
  suspendedAt                DateTime?              @map("suspended_at") @db.Timestamptz(6)
  /// Human-readable reason for account suspension.
  suspensionReason           String?                @map("suspension_reason")
  /// Business verification flag used across product workflows.
  isVerified                 Boolean                @default(false) @map("is_verified")
  /// Current creator privilege state.
  creatorStatus              CreatorStatus          @default(NOT_APPLIED) @map("creator_status")
  /// Timestamp when creator privileges were suspended.
  creatorSuspendedAt         DateTime?              @map("creator_suspended_at") @db.Timestamptz(6)
  /// Optional suspension expiry for creator privileges.
  creatorSuspensionExpiresAt DateTime?              @map("creator_suspension_expires_at") @db.Timestamptz(6)
  /// Reason for creator suspension.
  creatorSuspensionReason    String?                @map("creator_suspension_reason")
  /// Timestamp when creator privileges were revoked.
  creatorRevokedAt           DateTime?              @map("creator_revoked_at") @db.Timestamptz(6)
  /// Reason for creator revocation.
  creatorRevocationReason    String?                @map("creator_revocation_reason")
  /// Coarse onboarding progress indicator.
  onboardingStatus           OnboardingStatus       @default(NOT_STARTED) @map("onboarding_status")
  /// Date of birth used by dependency/age policy.
  birthDate                  DateTime?              @map("birth_date") @db.Date
  /// Derived minor snapshot used for fast policy filtering.
  isMinor                    Boolean                @default(false) @map("is_minor")
  /// Dependency state for custodian policy.
  dependencyStatus           DependencyStatus       @default(INDEPENDENT) @map("dependency_status")
  /// Timestamp of the most recent dependency-state change.
  dependencyStatusUpdatedAt  DateTime?              @map("dependency_status_updated_at") @db.Timestamptz(6)
  /// Time the user becomes eligible for independence under policy.
  independenceEligibleAt     DateTime?              @map("independence_eligible_at") @db.Timestamptz(6)
  /// Time the user actually became independent.
  becameIndependentAt        DateTime?              @map("became_independent_at") @db.Timestamptz(6)
  /// Last seen activity timestamp for analytics/support.
  lastActiveAt               DateTime?              @map("last_active_at") @db.Timestamptz(6)
  /// Creation timestamp.
  createdAt                  DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Update timestamp maintained automatically by Prisma.
  updatedAt                  DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  /// Soft-delete timestamp for preserving historical references.
  deletedAt                  DateTime?              @map("deleted_at") @db.Timestamptz(6)

  /// One-to-one profile with geo and institution context.
  profile                               UserProfile?
  /// Historical creator application submissions.
  creatorApplications                   CreatorApplication[]
  /// Libraries owned directly by this user.
  ownedLibraries                        Library[]                 @relation("UserOwnedLibraries")
  /// Access grants this user has received.
  libraryAccesses                       LibraryAccess[]           @relation("LibraryAccessUser")
  /// Access grants this user issued to others.
  libraryAccessesGranted                LibraryAccess[]           @relation("LibraryAccessGrantedBy")
  /// Platform subscriptions where this user benefits from the entitlement.
  platformSubscriptionsBenefiting       PlatformSubscription[]    @relation("PlatformSubscriptionBeneficiary")
  /// Platform subscriptions where this user is the payer.
  platformSubscriptionsPaying           PlatformSubscription[]    @relation("PlatformSubscriptionPayer")
  /// Platform subscriptions where this user operationally managed billing.
  platformSubscriptionsManaged          PlatformSubscription[]    @relation("PlatformSubscriptionManagedBy")
  /// Library subscriptions where this user benefits from the entitlement.
  premiumLibrarySubscriptionsBenefiting PaidLibrarySubscription[] @relation("PaidLibrarySubscriptionBeneficiary")
  /// Library subscriptions where this user is the payer.
  premiumLibrarySubscriptionsPaying     PaidLibrarySubscription[] @relation("PaidLibrarySubscriptionPayer")
  /// Library subscriptions where this user managed the billing action.
  premiumLibrarySubscriptionsManaged    PaidLibrarySubscription[] @relation("PaidLibrarySubscriptionManagedBy")
  /// File records uploaded by this user.
  uploadedFiles                         File[]                    @relation("FileUploader")
  /// Ratings authored by this user.
  ratings                               Rating[]
  /// Engagement events attributed to this user.
  engagementEvents                      EngagementEvent[]
  /// Notifications delivered to this user.
  notifications                         Notification[]
  /// Curriculum choices selected by this user.
  selectedCurricula                     UserSelectedCurriculum[]
  /// Image assets uploaded by this user.
  uploadedImageAssets                   ImageAsset[]              @relation("ImageAssetUploader")
  /// Custodian relationships where this user is the dependent.
  dependentCustodianRelationships       CustodianRelationship[]   @relation("DependentCustodianRelationships")
  /// Custodian relationships where this user is the custodian.
  custodianDependentRelationships       CustodianRelationship[]   @relation("CustodianDependentRelationships")
  /// Custodian invitations sent by this user.
  sentCustodianInvitations              CustodianInvitation[]     @relation("CustodianInvitationInviter")
  /// Custodian invitations addressed to this user.
  receivedCustodianInvitations          CustodianInvitation[]     @relation("CustodianInvitationRecipient")
  /// Custodian invitations attached to this dependent user.
  dependentCustodianInvitations         CustodianInvitation[]     @relation("CustodianInvitationDependent")
  /// Invitations this user accepted.
  acceptedCustodianInvitations          CustodianInvitation[]     @relation("CustodianInvitationAcceptedBy")
  /// Invitations this user revoked.
  revokedCustodianInvitations           CustodianInvitation[]     @relation("CustodianInvitationRevokedBy")
  /// Custodian relationships linked/created by this user.
  custodianRelationshipsLinked          CustodianRelationship[]   @relation("CustodianRelationshipLinkedBy")
  /// Delegated-access audit rows where this user is the real actor.
  delegatedAccessEventsAsActor          DelegatedAccessAudit[]    @relation("DelegatedAccessActor")
  /// Delegated-access audit rows where this user is the effective account.
  delegatedAccessEventsAsEffectiveUser  DelegatedAccessAudit[]    @relation("DelegatedAccessEffectiveUser")
  /// Institution memberships held by this user.
  institutionMemberships                InstitutionMembership[]   @relation("InstitutionMembershipUser")
  /// Institution memberships this user invited.
  institutionMembershipsInvited         InstitutionMembership[]   @relation("InstitutionMembershipInvitedBy")
  /// Company memberships held by this user.
  companyMemberships                    CompanyMembership[]       @relation("CompanyMembershipUser")
  /// Company memberships this user invited.
  companyMembershipsInvited             CompanyMembership[]       @relation("CompanyMembershipInvitedBy")

  /// Multi-column filter path for user admin/moderation dashboards.
  @@index([accountType, dependencyStatus, isMinor, isVerified, creatorStatus], map: "idx_users_account_type_dependency_minor_verified_creator")
  /// Supports platform-admin and status filtering.
  @@index([administrativeRole, status], map: "idx_users_administrative_role_status")
  /// Supports active-user recency lists.
  @@index([status, lastActiveAt], map: "idx_users_status_last_active")
  /// Supports lookups by active product email snapshot when present.
  @@index([primaryEmail], map: "idx_users_primary_email")
  /// Supports public profile routing and lookup by username.
  @@index([username], map: "idx_users_username")
  /// Supports soft-delete aware user filtering.
  @@index([deletedAt, status], map: "idx_users_deleted_at_status")
  /// Map this model to the existing users table.
  @@map("users")
}

/// One-to-one user profile holding location and institution context distinct from core auth identity.
model UserProfile {
  /// Shares the same primary key as the parent user row.
  userId                   String               @id @map("user_id") @db.Uuid
  /// Optional gender selection.
  gender                   Gender?
  /// ISO-3166 alpha-2 country code.
  countryCode              String               @map("country_code") @db.Char(2)
  /// State code within the selected country.
  stateCode                String?              @map("state_code")
  /// County code within the selected state.
  countyCode               String?              @map("county_code")
  /// Institution category snapshot captured from the user context.
  institutionCategory      InstitutionCategory? @map("institution_category")
  /// Institution level snapshot captured from the user context.
  institutionLevel         InstitutionLevel?    @map("institution_level")
  /// Optional institution currently associated with the profile.
  institutionId            String?              @map("institution_id") @db.Uuid
  /// Profile completeness score used for onboarding and nudges.
  profileCompletionPercent Int                  @default(0) @map("profile_completion_percent") @db.SmallInt
  /// Creation timestamp.
  createdAt                DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Update timestamp.
  updatedAt                DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// Back-reference to the owning user row.
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Country used for geo hierarchy and pricing context.
  country     Country      @relation(fields: [countryCode], references: [iso2])
  /// Institution currently attached to the profile, if any.
  institution Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)

  /// Supports country-based profile reporting.
  @@index([countryCode], map: "idx_user_profiles_country")
  /// Supports state filtering in regional lists.
  @@index([countryCode, stateCode], map: "idx_user_profiles_country_state")
  /// Supports institution member/profile lookups.
  @@index([institutionId], map: "idx_user_profiles_institution")
  /// Map this model to the existing user_profiles table.
  @@map("user_profiles")
}

/// User-selected curriculum preferences for personalization and defaults.
model UserSelectedCurriculum {
  /// Surrogate UUID primary key for the selection row.
  id             String         @id @default(uuid()) @db.Uuid
  /// Owning user.
  userId         String         @map("user_id") @db.Uuid
  /// Chosen curriculum.
  curriculumCode CurriculumCode @map("curriculum_code")
  /// Whether this is the user's primary curriculum.
  isPrimary      Boolean        @default(false) @map("is_primary")
  /// Creation timestamp.
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Update timestamp.
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// Owning user relation.
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Curriculum reference relation.
  curriculum Curriculum @relation(fields: [curriculumCode], references: [code], onDelete: Restrict)

  /// Prevents duplicate selections of the same curriculum by one user.
  @@unique([userId, curriculumCode], map: "uq_user_selected_curricula_user_curriculum")
  /// Supports quick discovery of the user's primary curriculum.
  @@index([userId, isPrimary], map: "idx_user_selected_curricula_user_primary")
  /// Map this model to the existing user_selected_curricula table.
  @@map("user_selected_curricula")
}

/// Relationship row connecting a dependent to a custodian with granular delegated permissions.
model CustodianRelationship {
  /// Internal UUID primary key.
  id                  String                      @id @default(uuid()) @db.Uuid
  /// Dependent user in the relationship.
  dependentUserId     String                      @map("dependent_user_id") @db.Uuid
  /// Custodian user in the relationship.
  custodianUserId     String                      @map("custodian_user_id") @db.Uuid
  /// Optional actor who linked the relationship.
  linkedByUserId      String?                     @map("linked_by_user_id") @db.Uuid
  /// Optional invitation that created the relationship.
  invitationId        String?                     @unique @map("invitation_id") @db.Uuid
  /// Current lifecycle state.
  status              CustodianRelationshipStatus @default(PENDING)
  /// Allows account-level management.
  canManageAccount    Boolean                     @default(false) @map("can_manage_account")
  /// Allows acting as the dependent.
  canActAsDependent   Boolean                     @default(false) @map("can_act_as_dependent")
  /// Allows settings management.
  canManageSettings   Boolean                     @default(false) @map("can_manage_settings")
  /// Allows billing management.
  canManageBilling    Boolean                     @default(false) @map("can_manage_billing")
  /// Allows viewing dependent activity.
  canViewActivity     Boolean                     @default(true) @map("can_view_activity")
  /// Allows managing other custodians.
  canManageCustodians Boolean                     @default(false) @map("can_manage_custodians")
  /// Timestamp when the link became active.
  linkedAt            DateTime?                   @map("linked_at") @db.Timestamptz(6)
  /// Timestamp when the link was revoked.
  revokedAt           DateTime?                   @map("revoked_at") @db.Timestamptz(6)
  /// Human-readable reason for revocation.
  revokedReason       String?                     @map("revoked_reason")
  /// Creation timestamp.
  createdAt           DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Update timestamp.
  updatedAt           DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// Relation to the dependent user.
  dependentUser         User                   @relation("DependentCustodianRelationships", fields: [dependentUserId], references: [id], onDelete: Cascade)
  /// Relation to the custodian user.
  custodianUser         User                   @relation("CustodianDependentRelationships", fields: [custodianUserId], references: [id], onDelete: Cascade)
  /// Optional relation to the actor who linked the pair.
  linkedBy              User?                  @relation("CustodianRelationshipLinkedBy", fields: [linkedByUserId], references: [id], onDelete: SetNull)
  /// Optional originating invitation.
  invitation            CustodianInvitation?   @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  /// Audit rows produced while operating through this relationship.
  delegatedAccessAudits DelegatedAccessAudit[]

  /// Supports active dependent-side lookups.
  @@index([dependentUserId, status], map: "idx_custodian_relationships_dependent_status")
  /// Supports active custodian-side lookups.
