  /// Chapter assignments under the classification.
  chapters FileClassificationChapter[]
  /// Topic assignments under the classification.
  topics   FileClassificationTopic[]
  /// Keyword assignments under the classification.
  keywords FileClassificationKeyword[]

  /// Supports subject-based content discovery.
  @@index([subjectId], map: "idx_file_classifications_subject")
  /// Map this model to the existing file_classifications table.
  @@map("file_classifications")
}

/// Canonical keyword dictionary used by file classifications.
model Keyword {
