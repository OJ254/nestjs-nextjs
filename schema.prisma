  deletedAt DateTime?          @map("deleted_at") @db.Timestamptz(6)
  /// Creation timestamp.
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Update timestamp.
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// Recipient user relation.
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Supports inbox queries by user/status/newest-first.
  @@index([userId, status, createdAt(sort: Desc)], map: "idx_notifications_user_status_created")
  /// Supports soft-delete aware cleanup jobs.
  @@index([userId, deletedAt, createdAt(sort: Desc)], map: "idx_notifications_user_deleted_created")
  /// Map this model to the existing notifications table.
  @@map("notifications")
}

/// Country reference table used for geo hierarchy, pricing, and organization profiles.
