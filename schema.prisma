/// Normalized classification anchor for a file, always tied to one subject.
model FileClassification {
  /// Internal UUID primary key.
  id        String   @id @default(uuid()) @db.Uuid
  /// One-to-one pointer to the classified file.
  fileId    String   @unique @map("file_id") @db.Uuid
  /// Subject used as the anchor for all deeper classification joins.
  subjectId String   @map("subject_id") @db.Uuid
  /// Creation timestamp.
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Update timestamp.
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// File relation.
  file     File                        @relation(fields: [fileId], references: [id], onDelete: Cascade)
  /// Subject relation.
  subject  Subject                     @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  /// Grade assignments under the classification.
