  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// Optional country relation.
  country Country? @relation(fields: [countryCode], references: [iso2], onDelete: SetNull)

  /// Prevents duplicate pricing rows for the same plan/cycle/country slice.
  @@unique([planCode, billingCycle, countryCode], map: "uq_platform_plan_prices_plan_cycle_country")
  /// Map this model to the existing platform_plan_prices table.
  @@map("platform_plan_prices")
}

