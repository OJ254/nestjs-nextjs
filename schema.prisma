  /// Library relation.
  library   Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  /// Recipient user relation.
  user      User    @relation("LibraryAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  /// Granting user relation.
  grantedBy User    @relation("LibraryAccessGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Restrict)

  /// One grant row per library/user pair.
  @@unique([libraryId, userId], map: "uq_library_access_library_user")
  /// Supports entitlement checks by recipient, library, status, and expiry.
  @@index([userId, libraryId, status, expiresAt], map: "idx_library_access_user_library_status_exp")
  /// Map this model to the existing library_access table.
  @@map("library_access")
}

/// Provider-backed platform subscription representing app-wide entitlements.
model PlatformSubscription {
  /// Internal UUID primary key.
  id                     String             @id @default(uuid()) @db.Uuid
  /// User receiving the platform entitlement; one current row per beneficiary in v1.
  beneficiaryUserId      String             @unique @map("beneficiary_user_id") @db.Uuid
  /// Optional payer for delegated billing scenarios.
  payerUserId            String?            @map("payer_user_id") @db.Uuid
  /// Optional operator who executed billing actions.
  managedByUserId        String?            @map("managed_by_user_id") @db.Uuid
  /// Billing provider.
  provider               BillingProvider?
  /// Provider customer id for Stripe linkage.
  providerCustomerId     String?            @map("provider_customer_id")
  /// Provider subscription id for Stripe linkage.
  providerSubscriptionId String?            @unique @map("provider_subscription_id")
  /// Internal platform plan code.
  planCode               PlatformPlan       @map("plan_code")
  /// Billing cadence.
  billingCycle           BillingCycle?      @map("billing_cycle")
  /// Provider/stateful subscription status.
  status                 SubscriptionStatus
  /// Trial start time.
  trialStart             DateTime?          @map("trial_start") @db.Timestamptz(6)
  /// Trial end time.
  trialEnd               DateTime?          @map("trial_end") @db.Timestamptz(6)
  /// Current billing period start time.
  currentPeriodStart     DateTime?          @map("current_period_start") @db.Timestamptz(6)
  /// Current billing period end time.
  currentPeriodEnd       DateTime?          @map("current_period_end") @db.Timestamptz(6)
  /// Creation timestamp.
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Update timestamp.
  updatedAt              DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// Beneficiary user relation.
  beneficiaryUser User  @relation("PlatformSubscriptionBeneficiary", fields: [beneficiaryUserId], references: [id], onDelete: Restrict)
  /// Payer user relation.
  payerUser       User? @relation("PlatformSubscriptionPayer", fields: [payerUserId], references: [id], onDelete: SetNull)
  /// Billing-operator relation.
  managedByUser   User? @relation("PlatformSubscriptionManagedBy", fields: [managedByUserId], references: [id], onDelete: SetNull)

  /// Supports delegated payer support workflows.
  @@index([payerUserId, status, currentPeriodEnd], map: "idx_platform_subs_payer_status_period_end")
  /// Supports beneficiary entitlement checks.
  @@index([beneficiaryUserId, status, currentPeriodEnd], map: "idx_platform_subs_beneficiary_status_period_end")
  /// Supports global renewal and dunning jobs.
  @@index([status, currentPeriodEnd], map: "idx_platform_subs_status_period_end")
  /// Map this model to the existing platform_subscriptions table.
  @@map("platform_subscriptions")
}

/// Country-aware pricing rows for platform plans.
model PlatformPlanPrice {
  /// Internal UUID primary key.
  id              String       @id @default(uuid()) @db.Uuid
  /// Platform plan being priced.
  planCode        PlatformPlan @map("plan_code")
  /// Billing cycle being priced.
  billingCycle    BillingCycle @map("billing_cycle")
  /// Optional country-specific override; null means global/default.
  countryCode     String?      @map("country_code") @db.Char(2)
  /// ISO-4217 currency code.
  currencyCode    String       @map("currency_code") @db.Char(3)
