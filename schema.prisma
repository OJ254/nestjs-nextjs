  /// States belonging to this country.
  states             CountryState[]
  /// Country-specific platform pricing rows.
  platformPlanPrices PlatformPlanPrice[]
  /// Companies located in this country.
  companies          Company[]
  /// Institutions located in this country.
  institutions       Institution[]

  /// Supports country activation filters.
  @@index([isActive], map: "idx_countries_is_active")
  /// Map this model to the existing countries table.
  @@map("countries")
}

/// State reference table nested under countries.
model CountryState {
  /// Internal UUID primary key.
  id          String @id @default(uuid()) @db.Uuid
  /// Parent country code.
  countryCode String @map("country_code") @db.Char(2)
  /// Stable state code within the country.
  stateCode   String @map("state_code")
  /// Human-readable state name.
  stateName   String @map("state_name")

  /// Parent country relation.
  country  Country       @relation(fields: [countryCode], references: [iso2], onDelete: Cascade)
  /// Counties under this state.
  counties StateCounty[]

  /// Prevents duplicate state codes inside one country.
  @@unique([countryCode, stateCode], map: "uq_country_states_country_state")
  /// Supports listing states for an active country.
  @@index([countryCode, stateName], map: "idx_country_states_country_name")
  /// Map this model to the existing country_states table.
  @@map("country_states")
}

/// County reference table nested under country/state.
model StateCounty {
  /// Internal UUID primary key.
  id          String @id @default(uuid()) @db.Uuid
  /// Parent country code.
  countryCode String @map("country_code") @db.Char(2)
  /// Parent state code.
  stateCode   String @map("state_code")
  /// Stable county code within the state.
  countyCode  String @map("county_code")
  /// Human-readable county name.
  countyName  String @map("county_name")

  /// Composite relation back to the parent state row.
  state CountryState @relation(fields: [countryCode, stateCode], references: [countryCode, stateCode], onDelete: Cascade)

  /// Prevents duplicate county codes inside one country/state pair.
  @@unique([countryCode, stateCode, countyCode], map: "uq_state_counties_country_state_county")
  /// Supports county listing within a state.
  @@index([countryCode, stateCode, countyName], map: "idx_state_counties_country_state_name")
  /// Map this model to the existing state_counties table.
  @@map("state_counties")
}

/// Company entity distinct from institutions, used for operating institutions and company-scoped memberships.
model Company {
  /// Internal UUID primary key.
  id              String   @id @default(uuid()) @db.Uuid
  /// Human-readable company name.
  name            String
  /// Optional user-facing slug for routing and discovery.
  slug            String?  @unique
  /// Country where the company is located.
  countryCode     String   @map("country_code") @db.Char(2)
  /// Optional state code within the country.
  stateCode       String?  @map("state_code")
  /// Optional county code within the state.
  countyCode      String?  @map("county_code")
  /// Business verification flag; defaults false until explicitly approved.
  isVerified      Boolean  @default(false) @map("is_verified")
  /// Whether the company is in the EdTech segment.
  isEdTechCompany Boolean  @default(false) @map("is_ed_tech_company")
  /// Creation timestamp.
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Update timestamp.
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// Country relation.
  country              Country             @relation(fields: [countryCode], references: [iso2], onDelete: Restrict)
  /// Institutions operated by this company.
  operatedInstitutions Institution[]       @relation("InstitutionOperatorCompany")
  /// Membership rows for users attached to the company.
  memberships          CompanyMembership[]

  /// Supports company filtering by country.
  @@index([countryCode], map: "idx_companies_country")
  /// Supports filtering by EdTech segment and verification.
  @@index([isEdTechCompany, isVerified], map: "idx_companies_ed_tech_verified")
  /// Supports slug-based routing while backfill remains nullable.
  @@index([slug], map: "idx_companies_slug")
  /// Map this model to the existing companies table.
  @@map("companies")
}

/// Institution entity distinct from companies and users, used for institution ownership and memberships.
model Institution {
  /// Internal UUID primary key.
  id                 String                        @id @default(uuid()) @db.Uuid
  /// Optional operator company responsible for this institution.
  operatorCompanyId  String?                       @map("operator_company_id") @db.Uuid
  /// Human-readable institution name.
  name               String
  /// Optional user-facing slug for routing and discovery.
  slug               String?                       @unique
  /// Country where the institution is located.
  countryCode        String                        @map("country_code") @db.Char(2)
  /// Optional state code within the country.
  stateCode          String?                       @map("state_code")
  /// Optional county code within the state.
  countyCode         String?                       @map("county_code")
  /// Institution category such as K12 or college.
  category           InstitutionCategory
  /// Optional institution level.
  level              InstitutionLevel?
  /// Business verification flag; defaults false until approved.
  isVerified         Boolean                       @default(false) @map("is_verified")
  /// Verification workflow state; starts pending until approval occurs.
  verificationStatus InstitutionVerificationStatus @default(PENDING) @map("verification_status")
  /// Timestamp when verification completed.
  verifiedAt         DateTime?                     @map("verified_at") @db.Timestamptz(6)
  /// Creation timestamp.
  createdAt          DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Update timestamp.
  updatedAt          DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// Optional operator company relation.
  operatorCompany  Company?                @relation("InstitutionOperatorCompany", fields: [operatorCompanyId], references: [id], onDelete: SetNull)
  /// Country relation.
  country          Country                 @relation(fields: [countryCode], references: [iso2], onDelete: Restrict)
  /// Profiles currently attached to the institution.
  profiles         UserProfile[]
  /// Institution membership rows.
  memberships      InstitutionMembership[]
  /// Curricula offered by the institution.
  offeredCurricula InstitutionCurriculum[]
  /// Libraries owned by the institution.
  ownedLibraries   Library[]               @relation("InstitutionOwnedLibraries")

  /// Supports operator-company lookup.
  @@index([operatorCompanyId], map: "idx_institutions_operator_company")
  /// Supports location/category/level filtering.
  @@index([countryCode, category, level], map: "idx_institutions_country_category_level")
  /// Supports verification workflow filtering.
  @@index([verificationStatus, isVerified], map: "idx_institutions_verification_status")
  /// Supports slug-based routing while backfill remains nullable.
  @@index([slug], map: "idx_institutions_slug")
  /// Map this model to the existing institutions table.
  @@map("institutions")
}

/// Join table capturing which curricula an institution offers.
model InstitutionCurriculum {
  /// Internal UUID primary key.
  id             String         @id @default(uuid()) @db.Uuid
  /// Institution offering the curriculum.
  institutionId  String         @map("institution_id") @db.Uuid
  /// Offered curriculum code.
  curriculumCode CurriculumCode @map("curriculum_code")
  /// Creation timestamp.
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Update timestamp.
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// Institution relation.
  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  /// Curriculum relation.
  curriculum  Curriculum  @relation(fields: [curriculumCode], references: [code], onDelete: Restrict)

  /// Prevents duplicate curriculum offerings per institution.
  @@unique([institutionId, curriculumCode], map: "uq_institution_curricula_institution_curriculum")
  /// Supports reverse lookups by curriculum.
  @@index([curriculumCode], map: "idx_institution_curricula_curriculum")
  /// Map this model to the existing institution_curricula table.
  @@map("institution_curricula")
}

// Note:
// PostgreSQL migrations should enforce the cross-row and cross-table rules Prisma cannot express directly.
// Key SQL hardening rules now include ownership XOR for libraries, student-elevation restrictions, verified-status consistency, one active premium price per library, one primary curriculum per user, non-negative pricing, rating range, and paid library billing fixed to YEAR_365_DAYS.
// Classification integrity across subject/chapter/topic and curriculum-level compatibility should remain enforced through SQL and service validations because those rules span multiple joined tables.
// File lifecycle rules are split intentionally: File.lifecycleStatus captures draft versus published intent, FileAsset.processingStatus tracks binary processing, PRIMARY_CONTENT existence is enforced via service workflow or deferred SQL trigger, and THUMBNAIL may be absent only when backend responses guarantee a fallback asset.
// State and county selectors should be exposed only for active countries; this is best enforced by query/service behavior rather than by denormalizing activity flags onto every state row.
