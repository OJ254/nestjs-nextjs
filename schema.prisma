/// Logical file/content record stored inside a library.
model File {
  /// Internal UUID primary key.
  id               String              @id @default(uuid()) @db.Uuid
  /// Parent library containing the file.
  libraryId        String              @map("library_id") @db.Uuid
  /// User who uploaded or created the file record.
  uploadedByUserId String              @map("uploaded_by_user_id") @db.Uuid
  /// Product material type used by downstream rules like answer-sheet validity.
  courseMaterial   CourseMaterial      @map("course_material")
  /// High-level file lifecycle; asset processing is tracked separately on FileAsset.
  lifecycleStatus  FileLifecycleStatus @default(DRAFT) @map("lifecycle_status")
  /// Timestamp when the file was published for consumption.
  publishedAt      DateTime?           @map("published_at") @db.Timestamptz(6)
  /// Timestamp when draft work most recently started or was intentionally kept as draft.
  draftSavedAt     DateTime?           @default(now()) @map("draft_saved_at") @db.Timestamptz(6)
  /// Denormalized aggregate view count retained for recommendation/ranking reads.
  viewCount        Int                 @default(0) @map("view_count")
  /// Whether AI participated in generating the content.
  isAiGenerated    Boolean             @default(false) @map("is_ai_generated")
  /// Creation timestamp.
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Update timestamp.
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// Parent library relation.
  library          Library             @relation(fields: [libraryId], references: [id], onDelete: Restrict)
  /// Uploading/owning user relation.
  uploadedBy       User                @relation("FileUploader", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  /// Binary assets attached to the logical file.
  assets           FileAsset[]
  /// Optional normalized classification row.
  classification   FileClassification?
  /// Immutable engagement history attached to the file.
  engagementEvents EngagementEvent[]

  /// Supports library content listings and uploader-based filters.
  @@index([libraryId, uploadedByUserId, courseMaterial], map: "idx_files_library_uploader_material")
  /// Supports publication and draft cleanup workflows.
  @@index([libraryId, lifecycleStatus, publishedAt], map: "idx_files_library_status_published_at")
  /// Supports recommendation/ranking queries by view count.
  @@index([libraryId, viewCount], map: "idx_files_library_view_count")
  /// Map this model to the existing files table.
  @@map("files")
}

/// Binary asset attached to a logical file.
model FileAsset {
  /// Internal UUID primary key.
  id               String               @id @default(uuid()) @db.Uuid
  /// Parent logical file.
  fileId           String               @map("file_id") @db.Uuid
  /// Role of the asset relative to the file.
  role             FileAssetRole        @map("role")
  /// Provenance of the asset.
  source           FileAssetSource      @map("source")
  /// Storage key in the backing object store.
  storageKey       String               @unique @map("storage_key")
  /// Optional original filename from upload time.
  originalFilename String?              @map("original_filename")
  /// MIME type of the stored object.
  mimeType         String               @map("mime_type")
  /// Size of the stored object in bytes.
  sizeBytes        BigInt               @map("size_bytes")
  /// Optional SHA-256 checksum.
  checksumSha256   String?              @map("checksum_sha256")
  /// Malware/trust scan result.
  scanStatus       FileScanStatus       @map("scan_status")
  /// Processing state for the asset.
  processingStatus FileProcessingStatus @map("processing_status")
  /// Creation timestamp.
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Update timestamp.
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// Parent file relation.
  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  /// Ensures one asset per role on a given file.
  @@unique([fileId, role], map: "uq_file_assets_file_role")
  /// Supports role/source resolution for file rendering.
  @@index([fileId, role, source], map: "idx_file_assets_file_role_source")
  /// Supports background jobs that process or rescan assets.
  @@index([role, processingStatus, scanStatus], map: "idx_file_assets_role_processing_scan")
  /// Map this model to the existing file_assets table.
  @@map("file_assets")
}

/// Binary image asset stored separately from file assets because lifecycle and usage differ.
